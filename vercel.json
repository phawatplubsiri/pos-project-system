{
  "version": 2,
  "framework": "vite",
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "cleanUrls": true,
  "rewrites": [
    { "source": "/(css|js|images|build)/(.*)", "destination": "/public/$1/$2" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
